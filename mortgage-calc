#!/bin/bash
# Mortgage Calculator CLI wrapper script

# Find the script directory
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
JAR_FILE="$SCRIPT_DIR/target/mortgage-calculator-1.0.0.jar"

# Check if JAR exists
if [ ! -f "$JAR_FILE" ]; then
    echo "Error: JAR file not found at $JAR_FILE"
    echo "Please run 'mvn clean package' first"
    exit 1
fi

# Try to find Java 21 or higher
JAVA_CMD="java"

# Check if JAVA_HOME is set and points to Java 21+
if [ -n "$JAVA_HOME" ]; then
    JAVA_CMD="$JAVA_HOME/bin/java"
fi

# Check Java version
JAVA_VERSION=$("$JAVA_CMD" -version 2>&1 | head -n 1 | cut -d'"' -f2 | cut -d'.' -f1)
if [ "$JAVA_VERSION" -lt 21 ]; then
    echo "Warning: This application requires Java 21 or higher"
    echo "Current Java version: $JAVA_VERSION"
    echo "Please set JAVA_HOME to point to Java 21+ or update your Java installation"
    exit 1
fi

# Execute the JAR with all arguments passed through
"$JAVA_CMD" -jar "$JAR_FILE" "$@"
