#!/bin/bash
# Mortgage Calculator CLI wrapper script

# Find the script directory (resolve symlinks)
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"

JAR_FILE="$SCRIPT_DIR/target/mortgage-calculator-1.0.0.jar"

# Check if JAR exists
if [ ! -f "$JAR_FILE" ]; then
    echo "Error: JAR file not found at $JAR_FILE"
    echo "Please run 'mvn clean package' first"
    exit 1
fi

# Try to find Java 21 or higher
JAVA_CMD="java"

# Try Homebrew OpenJDK (check multiple versions)
for version in 25.0.2 23.0.2 21.0.0; do
    if [ -x "/opt/homebrew/Cellar/openjdk/$version/libexec/openjdk.jdk/Contents/Home/bin/java" ]; then
        JAVA_CMD="/opt/homebrew/Cellar/openjdk/$version/libexec/openjdk.jdk/Contents/Home/bin/java"
        break
    fi
done

# Fallback to system java if Homebrew not found
if [ "$JAVA_CMD" = "java" ]; then
    if [ -x "/opt/homebrew/bin/java" ]; then
        JAVA_CMD="/opt/homebrew/bin/java"
    elif [ -n "$JAVA_HOME" ]; then
        JAVA_CMD="$JAVA_HOME/bin/java"
    fi
fi

# Execute the JAR with all arguments passed through
"$JAVA_CMD" -jar "$JAR_FILE" "$@"
